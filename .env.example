# ──────────────────────────────────────────────
# DroidWhisper — Environment Variables
# Copy this file to `.env` and fill in your keys.
# ──────────────────────────────────────────────

# OpenAI API key (for Whisper cloud transcription)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API key (for Gemini 3 Flash transcription)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Default transcription provider: local | openai_whisper | gemini_flash
DEFAULT_PROVIDER=local

# Default language code (BCP-47).  Leave blank for auto-detect.
DEFAULT_LANGUAGE=en
